---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) => d.toLocaleDateString("en-GB", { year: "numeric", month: "short", day: "numeric" });
---
<BaseLayout title="Writing - Dervis van Leersum" description="Articles and notes on Python, data platforms and developer experience.">
  <section class="articles">
    <div class="sec-label">Transmissions</div>
    <h1>Writing</h1>
    <p class="lede" style="margin-top: 22px; margin-bottom: 40px;">Notes on Python, data platforms, tooling and the occasional war story.</p>

    {articles.length === 0 ? (
      <p class="prose">No articles published yet - first transmission incoming.</p>
    ) : (
      <ul class="post-list">
        {articles.map((a) => {
          const href = a.data.externalUrl ?? `/articles/${a.id}`;
          const external = Boolean(a.data.externalUrl);
          return (
            <li>
              <a href={href} target={external ? "_blank" : undefined} rel={external ? "noopener" : undefined}>
                <time>{fmt(a.data.date)}</time>
                <span class="title">{a.data.title}{external && <span class="ext"> ↗</span>}</span>
                <span class="summary">{a.data.summary}</span>
                {a.data.tags.length > 0 && (
                  <span class="tags">{a.data.tags.map((t) => <span class="tag">{t}</span>)}</span>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>

  <style>
    .articles { padding: 40px 0; }
    .post-list { list-style: none; display: flex; flex-direction: column; gap: 4px; }
    .post-list a { display: grid; gap: 8px; padding: 24px; border: 1px solid var(--line); border-radius: 8px; text-decoration: none; background: var(--panel); transition: border-color .25s, transform .25s; }
    .post-list a:hover { border-color: rgba(70,200,255,0.35); transform: translateY(-3px); }
    .post-list time { font-family: var(--font-mono); font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--saber); }
    .post-list .title { font-family: var(--font-disp); font-size: 1.25rem; color: #fff; }
    .post-list .ext { color: var(--saber); }
    .post-list .summary { color: var(--muted); }
    .post-list .tags { margin-top: 6px; }
  </style>
</BaseLayout>
