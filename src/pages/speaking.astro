---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Speaking & Community — Dervis van Leersum" description="PyCon NL treasurer and Pythoneers organiser — community work and talks.">
  <section class="speaking">
    <div class="sec-label">Community</div>
    <h1>Speaking & Community</h1>
    <div class="prose" style="margin-top: 28px;">
      <p>I believe a healthy language ecosystem is built by the people who show up. Here's where I show up.</p>

      <h3>PyCon NL / PyNederland — Treasurer</h3>
      <p>I serve on the board of the Dutch Python association as <strong>treasurer</strong>, handling the finances behind the national conference and the year-round work of keeping the community running.</p>

      <h3>Pythoneers — Practice community</h3>
      <p>An active member of the Pythoneers practice community, where I help organise events such as <strong>Pythoneers Day</strong> — including a Streamlit workshop themed, naturally, around catching Pokémon.</p>
    </div>

    <div class="sec-label" style="margin-top: 50px;">Talks & Workshops</div>
    <div class="grid">
      <!-- Add talks as cards. Duplicate a block below. -->
      <div class="card" style="cursor: default;">
        <h3>Your next talk</h3>
        <p>This space is wired up and waiting. Drop a new entry here whenever you speak or run a workshop.</p>
        <div class="tags"><span class="tag">coming soon</span></div>
      </div>
    </div>
  </section>
  <style>.speaking { padding: 40px 0; }</style>
</BaseLayout>
