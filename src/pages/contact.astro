---
import BaseLayout from "../layouts/BaseLayout.astro";

const FORM_ENDPOINT = "https://submit-form.com/8HvIE4X9K";
const EMAIL = "dervis.vanleersum@gmail.com";
---
<BaseLayout title="Contact - Dervis van Leersum" description="Get in touch with Dervis van Leersum.">
  <section class="contact">
    <div class="sec-label">Comms</div>
    <h1>Transmit a message</h1>
    <p class="lede" style="margin-top: 22px;">Open to interesting problems in Python, data platforms and developer experience. Drop a line below, or email me directly at <a href={`mailto:${EMAIL}`} style="color: var(--saber);">{EMAIL}</a>.</p>

    <form id="contact-form" class="form" action={FORM_ENDPOINT} method="POST">
      <div class="row">
        <label>
          <span>Name</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label>
          <span>Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
      </div>
      <label>
        <span>Message</span>
        <textarea name="message" rows="6" required></textarea>
      </label>
      <!-- honeypot: bots fill this, humans never see it -->
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="gotcha" aria-hidden="true" />
      <button type="submit" class="btn btn-primary">Send transmission</button>
      <p id="form-status" class="status" role="status"></p>
    </form>
  </section>

  <script is:inline define:vars={{ FORM_ENDPOINT }}>
    const form = document.getElementById("contact-form");
    const status = document.getElementById("form-status");
    form?.addEventListener("submit", async (e) => {
      if (FORM_ENDPOINT.includes("REPLACE_ME")) {
        e.preventDefault();
        status.textContent = "⚠ Form endpoint not configured yet - see contact.astro.";
        status.style.color = "var(--hyper)";
        return;
      }
      e.preventDefault();
      status.textContent = "Transmitting…"; status.style.color = "var(--saber)";
      try {
        const res = await fetch(form.action, { method: "POST", body: new FormData(form), headers: { Accept: "application/json" } });
        if (res.ok) { form.reset(); status.textContent = "✓ Message received. I'll be in touch."; status.style.color = "#28c93f"; }
        else throw new Error();
      } catch {
        status.textContent = "✗ Something went wrong. Email me directly instead.";
        status.style.color = "var(--ember)";
      }
    });
  </script>

  <style>
    .contact { padding: 40px 0; max-width: 680px; }
    .form { margin-top: 36px; display: flex; flex-direction: column; gap: 20px; }
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 560px) { .row { grid-template-columns: 1fr; } }
    label { display: flex; flex-direction: column; gap: 8px; }
    label span { font-family: var(--font-mono); font-size: .7rem; letter-spacing: .18em; text-transform: uppercase; color: var(--muted); }
    input, textarea {
      background: rgba(3,5,10,0.6); border: 1px solid var(--line); border-radius: 6px;
      padding: 12px 14px; color: var(--text); font-family: var(--font-body); font-size: 1rem;
      transition: border-color .2s, box-shadow .2s; resize: vertical;
    }
    input:focus, textarea:focus { outline: none; border-color: var(--saber); box-shadow: 0 0 0 3px rgba(70,200,255,0.12); }
    .gotcha { position: absolute; left: -9999px; }
    .status { font-family: var(--font-mono); font-size: .85rem; min-height: 1.2em; }
    button { align-self: flex-start; cursor: pointer; border: none; }
  </style>
</BaseLayout>
