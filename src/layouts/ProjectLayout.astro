---
import BaseLayout from "./BaseLayout.astro";
import { MAIN_NAME } from "../config";

interface Props {
  title: string;
  summary: string;
  role?: string;
  period?: string;
  tech?: string[];
  link?: string;
  repo?: string;
  backHref?: string;
  backLabel?: string;
}
const { title, summary, role, period, tech = [], link, repo, backHref = "/#work", backLabel = "All work" } = Astro.props;
---
<BaseLayout title={`${title} - ${MAIN_NAME}`} description={summary}>
  <article class="project">
    <a class="back" href={backHref}>← {backLabel}</a>
    <div class="sec-label">Selected Work</div>
    <h1>{title}</h1>
    <p class="lede">{summary}</p>

    {(role || period) && (
      <dl class="meta">
        {role && <div><dt>Role</dt><dd>{role}</dd></div>}
        {period && <div><dt>When</dt><dd>{period}</dd></div>}
      </dl>
    )}

    <div class="prose"><slot /></div>

    {tech.length > 0 && (
      <div class="tech-block">
        <div class="sec-label">Stack</div>
        <div class="tags">{tech.map((t) => <span class="tag">{t}</span>)}</div>
      </div>
    )}

    {(link || repo) && (
      <div class="links">
        {link && <a class="btn btn-primary" href={link} target="_blank" rel="noopener">View project</a>}
        {repo && <a class="btn btn-ghost" href={repo} target="_blank" rel="noopener">Source</a>}
      </div>
    )}
  </article>

