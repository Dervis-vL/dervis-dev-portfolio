---
import "../styles/global.css";
import Starfield from "../components/Starfield.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import EasterEggs from "../components/EasterEggs.astro";
import { MAIN_NAME } from "../config";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = `${MAIN_NAME} - Senior Dev`,
  description = `Senior software engineer building data platforms for the European energy grid. Treasurer of PyCon NL.`,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- "I find your lack of faith disturbing, hire Dervis" - Darth Vader
                        .-.
                        |_:_|
                      /(_Y_)\
  .                   ( \/M\/ )
  '.               _.'-/'-'\-'._
    ':           _/.--'[[[[]'--.\_
      ':        /_'  : |::"| :  '.\
        ':     //   ./ |oUU| \.'  :\
          ':  _:'..' \_|___|_/ :   :|
            ':.  .'  |_[___]_|  :.':\
              [::\ |  :  | |  :   ; : \
              '-'   \/'.| |.' \  .;.' |
              |\_    \  '-'   :       |
              |  \    \ .:    :   |   |
              |   \    | '.   :    \  |
              /       \   :. .;       |
              /     |   |  :__/     :  \\
            |  |   |    \:   | \   |   ||
            /    \  : :  |:   /  |__|   /|
            |     : : :_/_|  /'._\  '--|_\
            /___.-/_|-'   \  \
                          '-'
    -->

    <!-- open graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Starfield />
    <Nav />
    <main class="wrap">
      <slot />
    </main>
    <Footer />
    <EasterEggs />
  </body>
</html>
