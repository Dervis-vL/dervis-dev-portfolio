astro---
// All the hidden fun, in one place. Numbered to match the README egg map.
import { SABER_GREEN, SABER_RED } from '../config';
---
<div id="toast"></div>

<!--
  +-----------------------------------------------+
  |  These aren't the droids you're looking for.  |
  |  But if you're reading the source...          |
  |  you're exactly the dev I'd want to hire.     |
  |  >> hint: type "force" to activate something. |
  +-----------------------------------------------+
-->

<script is:inline define:vars={{ SABER_GREEN, SABER_RED }}>
  (() => {
    // (4) console greeting for fellow devs
    console.log("%c  May the source be with you.\n  Like what you see? Let's talk.", "color:#ffe81f; font-family:monospace; font-size:13px; line-height:1.6;");
    console.log("%c> psst... try typing 'force' and click the dot in the logo.", "color:#46c8ff; font-family:monospace;");

    const toast = document.getElementById("toast");
    let timer;
    function showToast(msg) {
      if (!toast) return;
      toast.textContent = msg; toast.classList.add("show");
      clearTimeout(timer); timer = setTimeout(() => toast.classList.remove("show"), 2600);
    }

    // Restore the chosen side on every page load so it survives navigation.
    try {
      if (localStorage.getItem("darkSide") === "1") {
        window.__darkSide = true;
        document.body.classList.add("dark-side");
      }
    } catch (_) { /* private mode etc. fine to ignore */ }

    // (1) click the "." in the logo -> turn to the dark side
    const toggle = document.getElementById("forceToggle");
    if (toggle) toggle.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      window.__darkSide = !window.__darkSide;
      document.body.classList.toggle("dark-side", window.__darkSide);
      try { localStorage.setItem("darkSide", window.__darkSide ? "1" : "0"); } catch (_) {}
      showToast(window.__darkSide ? "You have turned to the dark side." : "Balance restored to the Force.");
    });

    // (2) Konami code -> hyperspace jump
    const konami = ["ArrowUp","ArrowUp","ArrowDown","ArrowDown","ArrowLeft","ArrowRight","ArrowLeft","ArrowRight","b","a"];
    let kBuf = [];
    addEventListener("keydown", (e) => {
      kBuf.push(e.key); kBuf = kBuf.slice(-konami.length);
      if (kBuf.join(",") === konami.join(",")) { window.__hyperjump && window.__hyperjump(); showToast("Punch it, Chewie."); }
    });

    // ── (3a) Lightsaber cursor – toggled by typing "force" ──────────────
    let saberOn = false, saberEl = null;
    let saberX = -1000, saberY = -1000, saberAngle = 0, saberDir = 1;
    let saberHx = 0, saberHy = 0;
    let cSpeed = 0, saberRaf = null, saberT0 = 0, flipTimer = null;
    let pmx = 0, pmy = 0, pmt = performance.now(), prevDark = false;

    function saberCfg() { return window.__darkSide ? SABER_RED : SABER_GREEN; }

    function applySaberImg() {
      if (!saberEl) return;
      const { src, w, hx, hy } = saberCfg();
      const img = saberEl.querySelector('img');
      img.src = src;
      img.style.cssText = `display:block;width:${w}px;user-select:none;-webkit-user-drag:none`;
      saberEl.style.transformOrigin = `${hx}px ${hy}px`;
      saberHx = hx; saberHy = hy;
    }

    function buildSaberEl() {
      if (saberEl) return;
      saberEl = document.createElement('div');
      saberEl.style.cssText = 'position:fixed;left:0;top:0;pointer-events:none;z-index:9999;will-change:transform;';
      saberEl.appendChild(document.createElement('img'));
      document.body.appendChild(saberEl);
      applySaberImg();
    }

    function scheduleSaberFlip() {
      clearTimeout(flipTimer);
      flipTimer = setTimeout(() => {
        if (!saberOn) return;
        saberDir = Math.random() < 0.5 ? 1 : -1;
        scheduleSaberFlip();
      }, 500 + Math.random() * 2500);
    }

    function saberLoop(now) {
      if (!saberOn) return;
      const dt = Math.min(now - saberT0, 50);
      saberT0 = now;
      cSpeed *= Math.pow(0.82, dt / 16.67);
      saberAngle += saberDir * cSpeed * 0.9 * dt;
      const isDark = !!window.__darkSide;
      if (isDark !== prevDark) { prevDark = isDark; applySaberImg(); }
      saberEl.style.transform = `translate(${saberX - saberHx}px,${saberY - saberHy}px) rotate(${saberAngle}deg)`;
      saberRaf = requestAnimationFrame(saberLoop);
    }

    function activateSaber() {
      saberOn = true;
      buildSaberEl();
      document.body.classList.add('saber-active');
      saberDir = Math.random() < 0.5 ? 1 : -1;
      scheduleSaberFlip();
      saberT0 = performance.now();
      saberRaf = requestAnimationFrame(saberLoop);
      try { localStorage.setItem("saberOn", "1"); } catch (_) {}
    }

    function deactivateSaber() {
      saberOn = false;
      document.body.classList.remove('saber-active');
      clearTimeout(flipTimer);
      if (saberRaf) { cancelAnimationFrame(saberRaf); saberRaf = null; }
      if (saberEl) { saberEl.remove(); saberEl = null; }
      try { localStorage.setItem("saberOn", "0"); } catch (_) {}
    }

    try { if (localStorage.getItem("saberOn") === "1") activateSaber(); } catch (_) {}

    addEventListener('mousemove', e => {
      const now = performance.now(), dt = now - pmt;
      if (dt > 0) cSpeed = Math.hypot(e.clientX - pmx, e.clientY - pmy) / dt;
      pmx = e.clientX; pmy = e.clientY; pmt = now;
      saberX = e.clientX; saberY = e.clientY;
    });
    // ── end Lightsaber cursor ────────────────────────────────────────────

    // (3) type "force" anywhere -> Force pulse + toggle lightsaber cursor
    let wordBuf = "";
    addEventListener("keydown", (e) => {
      if (e.key && e.key.length === 1) wordBuf = (wordBuf + e.key.toLowerCase()).slice(-5);
      if (wordBuf === "force") {
        document.body.classList.add("force-pulse");
        setTimeout(() => document.body.classList.remove("force-pulse"), 800);
        showToast("Use the Force, Dervis."); wordBuf = "";
        if (saberOn) deactivateSaber(); else activateSaber();
      }
    });

    // scroll reveal (shared util also lives here so every page gets it)
    const io = new IntersectionObserver((entries) => {
      entries.forEach((en) => { if (en.isIntersecting) { en.target.classList.add("in"); io.unobserve(en.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
  })();
</script>
