---
const links = [
  { href: "/#work", label: "Work" },
  { href: "/about", label: "About" },
  { href: "/articles", label: "Writing" },
  { href: "/speaking", label: "Speaking" },
  { href: "/contact", label: "Contact" },
];
---
<header>
  <div class="wrap">
    <nav>
      <a href="/" class="brand">DERVIS<b id="forceToggle" title="choose your side">.</b>DEV</a>
      <ul class="nav-links">
        {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
      <button class="hamburger" id="menuToggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <ul>
      {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>
  </div>
</header>

<style>
  header {
    position: sticky; top: 0; z-index: 20;
    backdrop-filter: blur(10px);
    background: linear-gradient(180deg, rgba(5,6,10,0.85), rgba(5,6,10,0.25));
    border-bottom: 1px solid var(--line);
  }
  nav { display: flex; align-items: center; justify-content: space-between; height: 66px; }
  .brand {
    font-family: var(--font-disp); font-weight: 700; letter-spacing: .22em;
    font-size: .95rem; text-transform: uppercase; color: #fff; text-decoration: none;
  }
  .brand b { color: var(--hyper); cursor: pointer; transition: text-shadow .3s; }
  .brand b:hover { text-shadow: 0 0 14px var(--hyper); }
  .nav-links { display: flex; gap: 30px; list-style: none; }
  .nav-links a {
    font-family: var(--font-disp); font-size: .78rem; letter-spacing: .16em;
    text-transform: uppercase; color: var(--muted); text-decoration: none;
    position: relative; padding-bottom: 6px; transition: color .25s;
  }
  .nav-links a::after {
    content: ""; position: absolute; left: 0; bottom: 0; height: 2px; width: 0;
    background: var(--saber); border-radius: 2px;
    box-shadow: 0 0 8px var(--saber), 0 0 16px var(--saber);
    transition: width .28s cubic-bezier(.4,0,.2,1);
  }
  .nav-links a:hover { color: #fff; }
  .nav-links a:hover::after { width: 100%; }

  /* Hamburger button */
  .hamburger {
    display: none; flex-direction: column; justify-content: center; gap: 5px;
    width: 36px; height: 36px; background: none; border: none; cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block; height: 2px; width: 100%; background: var(--muted);
    border-radius: 2px; transition: transform .3s, opacity .3s, background .3s;
    transform-origin: center;
  }
  .hamburger:hover span { background: #fff; }
  /* X state */
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile dropdown */
  .mobile-menu {
    display: none; overflow: hidden;
    max-height: 0; transition: max-height .35s cubic-bezier(.4,0,.2,1);
    background: rgba(5,6,10,0.97);
    border-bottom: 1px solid var(--line);
  }
  .mobile-menu.open { max-height: 320px; }
  .mobile-menu ul { list-style: none; padding: 12px 0 20px; }
  .mobile-menu li { border-top: 1px solid var(--line); }
  .mobile-menu a {
    display: block; padding: 14px 20px;
    font-family: var(--font-disp); font-size: .78rem; letter-spacing: .16em;
    text-transform: uppercase; color: var(--muted); text-decoration: none;
    transition: color .2s, padding-left .2s;
  }
  .mobile-menu a:hover { color: #fff; padding-left: 28px; }

  @media (max-width: 640px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .mobile-menu { display: block; }
  }
</style>

<script>
  const toggle = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    toggle.classList.toggle('open', open);
    toggle.setAttribute('aria-expanded', String(open));
  });
  // Close menu when a link is clicked
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.remove('open');
      toggle?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
